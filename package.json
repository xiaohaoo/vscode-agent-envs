{
  "name": "vscode-agent-envs",
  "displayName": "Agent Envs",
  "description": "Manage and switch Claude Code and Codex CLI profiles from VS Code.",
  "version": "0.0.11",
  "publisher": "xiaohaoo",
  "license": "MIT",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaohaoo/vscode-agent-envs.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:agentEnvs.profilesView",
    "onCommand:agentEnvs.refresh",
    "onCommand:agentEnvs.addProfile",
    "onCommand:agentEnvs.editProfile",
    "onCommand:agentEnvs.deleteProfile",
    "onCommand:agentEnvs.applyProfile",
    "onCommand:agentEnvs.openConfig",
    "onCommand:agentEnvs.revealNativeConfig"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentEnvs.addProfile",
        "title": "Add Profile",
        "category": "Agent Envs",
        "icon": "$(add)"
      },
      {
        "command": "agentEnvs.editProfile",
        "title": "Edit Profile",
        "category": "Agent Envs",
        "icon": "$(edit)"
      },
      {
        "command": "agentEnvs.deleteProfile",
        "title": "Delete Profile",
        "category": "Agent Envs",
        "icon": "$(trash)"
      },
      {
        "command": "agentEnvs.refresh",
        "title": "Refresh Profiles",
        "category": "Agent Envs",
        "icon": "$(refresh)"
      },
      {
        "command": "agentEnvs.applyProfile",
        "title": "Apply Profile",
        "category": "Agent Envs",
        "icon": "$(check)"
      },
      {
        "command": "agentEnvs.openConfig",
        "title": "Open Agent Envs Config",
        "category": "Agent Envs",
        "icon": "$(json)"
      },
      {
        "command": "agentEnvs.revealNativeConfig",
        "title": "Reveal Native Config",
        "category": "Agent Envs",
        "icon": "$(go-to-file)"
      }
    ],
    "configuration": {
      "title": "Agent Envs",
      "properties": {}
    },
    "menus": {
      "view/title": [
        {
          "command": "agentEnvs.addProfile",
          "when": "view == agentEnvs.profilesView",
          "group": "navigation"
        },
        {
          "command": "agentEnvs.refresh",
          "when": "view == agentEnvs.profilesView",
          "group": "navigation"
        },
        {
          "command": "agentEnvs.openConfig",
          "when": "view == agentEnvs.profilesView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "agentEnvs.addProfile",
          "when": "view == agentEnvs.profilesView && viewItem == agent",
          "group": "inline"
        },
        {
          "command": "agentEnvs.applyProfile",
          "when": "view == agentEnvs.profilesView && viewItem == profile",
          "group": "inline"
        },
        {
          "command": "agentEnvs.editProfile",
          "when": "view == agentEnvs.profilesView && viewItem == profile",
          "group": "inline"
        },
        {
          "command": "agentEnvs.deleteProfile",
          "when": "view == agentEnvs.profilesView && viewItem == profile",
          "group": "inline"
        },
        {
          "command": "agentEnvs.revealNativeConfig",
          "when": "view == agentEnvs.profilesView && viewItem == agent",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentEnvs",
          "title": "Agent Envs",
          "icon": "resources/agent-envs.svg"
        }
      ]
    },
    "views": {
      "agentEnvs": [
        {
          "id": "agentEnvs.profilesView",
          "name": "Profiles",
          "icon": "resources/agent-envs.svg",
          "contextualTitle": "Agent Envs"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "smol-toml": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/vscode": "1.96.0",
    "typescript": "^6.0.3"
  }
}
